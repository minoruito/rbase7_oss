<!-- Navbar -->
<nav class="main-header navbar navbar-expand navbar-white navbar-light">
  <!-- Left navbar links -->
  <ul class="navbar-nav">
    <li class="nav-item">
      <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
    </li>
  </ul>
  
  <!-- Left navbar links -->
  <ul class="navbar-nav">
  </ul>

  <!-- Right navbar links -->
  <ul class="navbar-nav ml-auto">
    <!-- Messages Dropdown Menu -->
    <% if admin_user_signed_in? %>
      <li class="nav-item dropdown">
        <a class="nav-link" data-toggle="dropdown" href="#">
          <%= active_site_name %>
        </a>

        <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
          <% current_admin_user.sites.all.each do |site| %>
            <%= link_to site.site_name, top_path(id: site.id), class: "dropdown-item" %>
            <% if current_admin_user.sites.last != site %>
              <div class="dropdown-divider"></div>
            <% end %>
            <!-- Message End -->
          <% end %>
        </div>
      </li>
    <% end %>
    <% if admin_user_signed_in? %>
      <li class="nav-username nav-item d-none d-sm-inline-block">
        <span class="inline"><%= current_admin_user.name %>(<%= link_to t(:"menu.top.edit_link"), edit_admin_user_registration_path(edit_clear: true), class: "nav-link" %>)</span>
      <li class="nav-item d-none d-sm-inline-block">
        <%  unless (@sso_url and require_sso_logout?) %>
          <%= link_to t(:"menu.top.sign_out"), destroy_admin_user_session_path, method: :delete, id: "logout", data: {turbo: false}, class: "nav-link" %>
        <% else %>
          <%= form_with url: @sso_url, method: :get, local: true, id: "sign_out_form" do |form| %>
            <% @sso_params.each do |k, v| %>
              <%= form.hidden_field k, value: v %>
            <% end %>
            <%= link_to t(:"menu.top.sign_out"), "javascript:$('#sign_out_form').submit();", id: "sso-logout", class: "nav-link" %>
          <% end %>
        <% end %>
      </li>
    <% else %>
      <li class="nav-item d-none d-sm-inline-block">
        <%= link_to t(:"menu.top.sign_in"), new_admin_user_session_path, class: "nav-link" %>
      </li>
    <% end %>
    <% if ::SystemSetting.get_setting(:display_google_translate, current_site_id || Site.order(:id).first.id).to_s == "1" %>
      <li class="nav-item d-none d-sm-inline-block">
        <div id="google_translate_element"></div>
      </li>
    <% end %>
  </ul>
</nav>
<!-- /.navbar -->
