<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.custom_fields.new.title")%></h1>
        <small><%= t(:"views.custom_fields.new.header_guide")%></small>
      </div>
    </div>
  </div>
</div>
<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <%= simple_form_for([:admin, @custom_field], builder: RbaseFormBuilder, html: {data: {turbo_confirm: t(:"views.common.create_confirm_message"), turbo: true, action: "change->admin--custom_fields#form_change"}}) do |f| %>
            <div class="card-body">
              <%= f.error_notification %>
              <div class="form-group">
                <%= render partial: 'form', locals: {form: f} %>
              </div>
            </div>
            <div class="card-footer">
              <%= f.submit t(:"views.custom_fields.new.button_create"), class: "btn btn-primary btn-sm"%>
              <%= link_to t(:"views.custom_fields.new.button_cancel"), admin_custom_fields_path, class: "btn btn-default btn-sm btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>


