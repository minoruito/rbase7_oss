<div class="form-group form-inline input-group-sm align-items-start">
  <%= form.input :template_div, as: :select, collection: MailTemplate.template_div_options, input_html: {col: 2} %>
  <%= form.input :template_name, input_html: {col: 5} %>
</div>

<div class="form-group form-inline input-group-sm align-items-start">
  <%= form.input :from_address, as: :select, collection: MailTemplate.from_address_options, input_html: {col: 3} %>
  <%= form.input :to_address, as: :select, collection: MailTemplate.to_address_options, input_html: {col: 3}  %>
</div>
<div class="form-group form-inline input-group-sm align-items-start">
  <%= form.input :subject, input_html: {col: 5} %>
</div>
<div class="form-group form-inline input-group-sm align-items-start">
  <%= form.input :body, as: :text, input_html: {col: 8, rows: 12, rolw: 120} %>
</div>
<div class="form-group form-inline input-group-sm align-items-start">
  <%= form.input :site_ids, as: :check_boxes,
                 collection: @sites.map{|x| [x.site_name,x.id]},
                 item_wrapper_class: "form-check-inline"
  %>
</div>
<div class="form-group form-inline input-group-sm align-items-start">
  <%= form.input :enable %>
  <%= form.input :disable_notice %>
</div>
