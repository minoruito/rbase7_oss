<% flash_notice = flash.now[:notice].presence || flash[:notice] %>
<% flash_alert = flash.now[:alert].presence || flash[:alert] %>
<%= turbo_frame_tag "entry-turbo-message" do %>
  <% if flash_notice %>
    <% if flash_notice.is_a?(Array) %>
      <% flash_notice.each do |notice| %>
        <div class="alert alert-success alert-dismissible fade show show_alert_both" role="alert">
          <%= notice %>
          <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
      <% end %>
    <% else %>
      <div class="alert alert-success alert-dismissible fade show <%= flash_alert ? 'show_alert_both' : ''%>" role="alert">
        <%= flash_notice %>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
    <% end %>
  <% end %>
  <% if flash_alert %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= flash_alert %>
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  <% end %>
<% end %>
