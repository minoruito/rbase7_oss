<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.reports.show.title")%></h1>
        <small><%= t(:"views.sites.reports.header_guide")%></small>
      </div>
    </div>
  </div>
</div>
<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <%= simple_form_for([:admin, @report], builder: RbaseFormBuilder, html: {data: {turbo_confirm: t(:"views.common.update_confirm_message"), multipart: true}, id: :fileupload}) do |f| %>
            <div class="card-body">
              <%= f.error_notification %>
              <div class="form-group">
                <%= render partial: 'show_form', locals: {form: f} %>
              </div>
            </div>
            <div class="card-footer">
              <%= link_to t(:"views.reports.show.button_back"), admin_reports_path, class: "btn btn-default btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  Rbase.showFormDisbaled();
</script>
