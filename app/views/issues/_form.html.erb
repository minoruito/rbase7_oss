<div class="box box-primary">
  <div class="box-header with-border">
    <%= t(:'views.issues.blockquote.issue_information') %>
  </div>
  <div class="box-body">
    <div class="form-group form-inline input-group-sm align-items-start">
      <%= form.input :title, input_html: {col: 5} %>
    </div>
    <div class="form-group form-inline input-group-sm align-items-start">
      <%= form.input :assigned_id, as: :select, collection: @assigns.map{|x|[x.name, x.id]}, input_html: {col: 3} %>
    </div>
    <div class="form-group form-inline input-group-sm align-items-start">
      <%= form.input :issue_type_id, as: :select, collection: @issue_types.map{|x|[x.issue_type_name, x.id]}, input_html: {id: :issue_type_id, col: 3} %>
      <%= render partial: 'form_workflow_state_for_new_or_edit' %>
    </div>
    <div class="form-group form-inline input-group-sm align-items-start">
      <%= form.input :priority, as: :select, collection: ::Issue.priority_options, input_html: {col: 3} %>
      <%= form.input :limited_at, as: :string, input_html: {type: "date", col: 2} %>
    </div>
    <div class="form-group form-inline input-group-sm align-items-start">
      <%= form.input :expression, as: :text, input_html: {rows: 5, col: 10} %>
    </div>
    <div id = "custom_field">
      <%= render partial: 'form_issue_custom_fields', locals: {form: form} %>
    </div>
  </div>
</div>