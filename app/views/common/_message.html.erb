<%= turbo_frame_tag "entry-turbo-message" do %>
  <% if flash[:notice] %>
    <% if flash[:notice].is_a?(Array) %>
      <% flash[:notice].each do |notice| %>
        <div class="alert alert-success alert-dismissible fade show show_alert_both" role="alert">
          <%= notice %>
          <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
      <% end %>
    <% else %>
      <div class="alert alert-success alert-dismissible fade show <%= flash[:alert] ? 'show_alert_both' : ''%>" role="alert">
        <%= flash[:notice] %>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
    <% end %>
  <% end %>
  <% if flash[:alert] %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= flash[:alert] %>
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  <% end %>
<% end %>
