<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.mail_templates.index.title")%></h1>
      </div>
      <div class="col-sm-6">
        <div class="float-sm-right">
          <%= link_to t(:"views.mail_templates.index.button_new"), new_admin_mail_template_path, class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <div class="card-title"></div>
          <div class="card-body">
            <%= page_entries_info @mail_templates %>
            <table class="table table-hover table-striped table-sm">
              <% unless @mail_templates.empty? %>
                <thead class="thead-dark">
                  <tr>
                    <th><%= t(:"views.mail_templates.fields.mail_template_div") %></th>
                    <th><%= t(:"views.mail_templates.fields.mail_template_name") %></th>
                    <th><%= t(:"views.mail_templates.fields.subject") %></th>
                    <th><%= t(:"views.mail_templates.fields.from") %></th>
                    <th><%= t(:"views.mail_templates.fields.to") %></th>
                    <th><%= t(:"views.mail_templates.fields.enable") %></th>
                    <th colspan="2"><%= t(:"views.mail_templates.fields.action") %></th>
                  </tr>
                </thead>
                <tbody>
                  <% @mail_templates.each do |mail_template| %>
                    <tr>
                      <td><%= mail_template.template_div_name %></td>
                      <td><%= link_to mail_template.template_name, admin_mail_template_path(mail_template)%></td>
                      <td><%= mail_template.subject %></td>
                      <td><%= mail_template.from_address_name %></td>
                      <td><%= mail_template.to_address_name %></td>
                      <td><%= mail_template.enable_name %></td>
                      <td>
                        <%= link_to t(:"views.mail_templates.index.table_mail_templates.button_edit"), edit_admin_mail_template_path(mail_template, clear: true), class: "btn btn-primary btn-sm" %>
                        <%= link_to t(:"views.mail_templates.index.table_mail_templates.button_destroy"), admin_mail_template_path(mail_template), data: { turbo_method: :delete, turbo_confirm: t(:"views.common.destroy_confirm_message") }, class: "btn btn-danger btn-sm" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              <% end %>
            </table>
            <%= paginate @mail_templates %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
