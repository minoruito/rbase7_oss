<%= turbo_frame_tag 'entry-forms' do %>
  <table class="table table-hover table-striped table-condensed">
    <thead>
      <tr>
        <th><%= t(:"views.workflows.edit.table_workflow_states.title.state_cd")%></th>
        <th><%= t(:"views.workflows.edit.table_workflow_states.title.state_name")%></th>
        <th><%= t(:"views.workflows.edit.table_workflow_states.title.default_value")%></th>
        <th><%= t(:"views.workflows.edit.table_workflow_states.title.end_point")%></th>
        <th><%= t(:"views.workflows.edit.table_workflow_states.title.deleted_state")%></th>
        <th><%= t(:"views.workflows.edit.table_workflow_states.title.sort")%></th>
        <th colspan="3"><%= t(:"views.workflows.edit.table_workflow_states.title.action")%></th>
      </tr>
    </thead>
    <tbody>
      <% if @workflow_states.empty? %>
        <tr>
          <td colspan="5">No data</td>
        </tr>
      <% end %>
      <% @workflow_states.each do |workflow_state| %>
        <tr>
          <td><%= link_to "#{workflow_state.state_cd}", admin_workflow_workflow_state_path(@workflow, workflow_state) %></td>
          <td><%= workflow_state.state_name %></td>
          <td><%= show_check(workflow_state.default_value) %></td>
          <td><%= show_check(workflow_state.end_point) %></td>
          <td><%= show_check(workflow_state.deleted_state) %></td>
          <td></td>
          <td>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
