<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.users.index.title")%></h1>
      </div>
      <div class="col-sm-6">
        <div class="float-sm-right">
          <%= link_to t(:"views.users.index.button_new"), new_admin_user_path(clear: true), class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header">
          </div>
          <div class="collapse show" id="condition-card">
            <%= simple_form_for @condition, url: admin_users_path, method: :get do |f| %>
              <div class="card-body">
                <%= f.error_notification %>
                <div class="form-group">
                  <%= render partial: 'search_conditions', locals: {form: f} %>
                </div>
              </div>
              <div class="card-footer">
                <%= f.submit t(:"views.issues.index.button_search"), class: "btn btn-primary btn-sm"%>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-12">
        <%= render partial: 'search_results' %>
      </div>
    </div>
  </div>
</section>

