<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.roles.edit.title")%></h1>
        <small><%= t(:"views.roles.edit.header_guide")%></small>
      </div>
    </div>
  </div>
</div>
<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <%= simple_form_for([:admin, @role], builder: RbaseFormBuilder, html: {data: {turbo_confirm: t(:"views.common.update_confirm_message"), turbo: true, action: "change->admin--roles#form_change"}}) do |f| %>

            <div class="card-body">
              <%= f.error_notification %>
              <div class="form-group">
                <%= render partial: 'form', locals: {form: f} %>
              </div>
            </div>
            <div class="card-body">
             <a class="btn btn-default btn-sm" id="button_select_all" href="#select-all"><i class="glyphicon glyphicon-check"></i>Select all</a>
             <a class="btn btn-default btn-sm" id="button_unselect_all" href="#unselect-all"><i class="glyphicon glyphicon-unchecked"></i>Unselect all</a>
             <%= render partial: 'form_role_actions', locals: {form: f} %>
            </div>
            <div class="card-footer">
              <%= f.submit t(:"views.roles.edit.button_update"), class: "btn btn-primary btn-sm"%>
              <%= link_to t(:"views.roles.edit.button_cancel"), admin_roles_path, class: "btn btn-default btn-sm btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>


