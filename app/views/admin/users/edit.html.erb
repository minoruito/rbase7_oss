<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.users.edit.title")%></h1>
        <small><%= t(:"views.users.edit.header_guide")%></small>
      </div>
    </div>
  </div>
</div>
<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <%= simple_form_for(@user, builder: RbaseFormBuilder, html: {data: {turbo_confirm: t(:"views.common.update_confirm_message"), turbo: true, action: "change->admin--users#form_change"}}) do |f| %>

            <div class="card-body">
              <%= render partial: 'form', locals: {f: f} %>
            </div>
            
            <div class="card-footer">
              <%= f.submit t(:"views.users.edit.button_update"), class: "btn btn-primary btn-sm" %>
              <%= link_to t(:"views.users.edit.button_cancel"), admin_users_path, class: "btn btn-default btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

